# Database Credentials (PostgreSQL)
DATABASE_URL=postgresql://filedeck:filedeckpassword@localhost:5432/filedeck?schema=public

# Cache & Background Queue (Redis)
REDIS_URL=redis://localhost:6379

# Storage Settings
STORAGE_PROVIDER=s3
STORAGE_BUCKET=filedeck-files
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_ENDPOINT=https://your-cloudflare-r2-or-s3-endpoint.com

# Server Configurations
PORT=5000
FILE_TTL_SECONDS=3600
MAX_UPLOAD_SIZE_MB=500
NODE_ENV=development
